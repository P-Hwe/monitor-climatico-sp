# Copie este arquivo para ".env" e ajuste conforme necessário.
# A API Open-Meteo não exige chave -- não há nada obrigatório para configurar.

# Local (padrão, não precisa mudar): SQLite em arquivo
# DATABASE_URL=sqlite:///monitor_climatico.db

# Producao (Railway/Render): Postgres fornecido pela plataforma
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Intervalo de coleta em minutos (clima muda devagar; 30 min e um bom padrao)
COLETA_INTERVALO_MINUTOS=30
